# Copy to .env and fill in secrets. Do not commit .env.

# --- Meta / Google ---
META_ACCESS_TOKEN=
AD_ACCOUNT_ID=
META_GRAPH_API_VERSION=v18.0

# Shop map: multiline JSON in repo file (recommended)
SHOP_NAME_MAP_PATH=shop_name_map.json
# Fallback only: single-line JSON (optional)
# SHOP_NAME_MAP={"938493152688096":"Lounge & Skin 尖沙嘴"}

# Shop daily total (HKD) and BUN vs HK split ratio (JSON)
SHOP_CONFIGS='{"Olase 旺角店": {"total": 830, "bun_ratio": 0.4}}'

# Per-strategy target CPC for pause / scale logic (JSON, HKD)
# STRATEGY_TARGET_CPC={"LTV":35,"BUN":1.5,"GENERAL":18,"NEW":20}

# LTV detection (comma-separated substrings in ad name/body)
# LTV_KEYWORDS=Gentlelase,755,脫毛

# LTV allowed CPC vs GENERAL target (multiplier)
# LTV_VALUE_MULTIPLIER=2.0

# New ad protection window (hours)
# NEW_AD_PROTECTION_HOURS=72

# New-post / pending-tests: reserve per pending entry (HKD). Each entry in pending_tests.json
# contributes this amount to BUN or HK pool reserve (classify_strategy on post message).
# Two BUN pending posts = 2x reserve from bun_target. Also used for P00 rows in Action Plan.
# Does NOT lower SHOP_CONFIGS "total": that stays the shop gross day cap; reserve is taken only
# from the matching pool (HK vs BUN), so existing-ad suggestions + reserves ≈ gross total.
NEW_AD_TEST_BUDGET=150

# Fallback min daily budget when API min absent (HKD); floor uses max(API_min+1, this)
MIN_DAILY_BUDGET=8

# --- Tier bands (cumulative from best / lowest CPC). Remainder after "tail" = bottom tier.
# TIER_CUTS={"champion":0.05,"strong":0.15,"middle":0.60,"explore":0.80,"tail":0.95}

# --- Budget allocator (HK pool: LTV score multiplier on 1/CPC)
# LTV_BUDGET_WEIGHT=1.5
# Upper cap vs current budget: middle tier
# BUDGET_CAP_MIDDLE=1.2
# Upper cap vs current: champion + strong (<=0 means effectively no cap)
# BUDGET_CAP_CHAMPION_STRONG=1.5
# Top fraction of pool for residual fill / trim (was hard-coded 0.5)
# ALLOC_RESIDUAL_TOP_FRACTION=0.5

# --- Sheet / no-op (avoid micro budget churn)
# Relative change below this => show「維持」and snap suggestion to current
# BUDGET_NO_OP_THRESHOLD_DEFAULT=0.10
# Stricter band for champion / strong tiers
# BUDGET_NO_OP_THRESHOLD_TOP=0.15
# Forbid suggested budget below current for champion/strong unless PAUSE_ONLY
# BLOCK_DOWNGRADE_CHAMPION_STRONG=true

# Optional future: persist last suggestion for cool-down (not wired in code yet)
# BUDGET_HISTORY_ENABLED=false
# BUDGET_HISTORY_PATH=budget_history.json

# --- Pool sample gates (ai_optimizer)
# MIN_ACTIVE_ADS_PER_SHOP=3
# MIN_POOL_SIZE=3
# MAX_RUNNING_ADS=15

# --- Google Sheets ---
SHEET_NAME=AdSurvivor_Report
RAW_SHEET_TAB=Sheet1
REFINED_SHEET_TAB=Sheet2
# ACTION_PLAN_TAB=AI_Action_Plan
