# Copy to .env and fill in secrets. Do not commit .env.

# --- Meta / Google ---
META_ACCESS_TOKEN=
AD_ACCOUNT_ID=
META_GRAPH_API_VERSION=v18.0

# --- config.json (canonical) ---
# SHOP_NAME_MAP, SHOP_CONFIGS (all shops, p00_* ad set ids, totals), STRATEGY_TARGET_CPC, LTV_KEYWORDS,
# NEW_AD_PROTECTION_HOURS, NEW_AD_TEST_BUDGET, NEW_AD_TEST_SCAN_PER_PAGE, NEW_AD_TEST_POSTS,
# GOOGLE_CREDENTIALS_PATH live in config.json. Env vars below override when set (non-empty).

# Optional: separate shop map JSON file (overrides config.json SHOP_NAME_MAP if this file loads OK).
# Leave unset to use SHOP_NAME_MAP from config.json.
# SHOP_NAME_MAP_PATH=shop_name_map.json
# Optional: inline JSON override after file
# SHOP_NAME_MAP={"938493152688096":"Lounge & Skin 撠???}

# Active shops + per-shop overrides (JSON). If non-empty, ONLY these shop keys run; each merges with
# the same key in config.json SHOP_CONFIGS (env fields win). Omit or use {} to run all shops from config.json.
# Per-shop optional keys: new_ad_test_scan_per_page, new_ad_test_posts, p00_hk_adset_id, etc.
# Example (single shop, tweak budget): SHOP_CONFIGS='{"OLase ??銵?": {"total": 700, "bun_ratio": 0.4}}'
# SHOP_CONFIGS='{"Olase ?箄?摨?: {"total": 830, "bun_ratio": 0.4}}'

# Override config.json / defaults (uncomment to use):
# STRATEGY_TARGET_CPC={"LTV":35,"BUN":1.5,"GENERAL":18,"NEW":20}
# LTV_KEYWORDS=Gentlelase,755,?急?
# LTV_VALUE_MULTIPLIER=2.0
# NEW_AD_PROTECTION_HOURS=72
# NEW_AD_TEST_BUDGET=50
# NEW_AD_TEST_SCAN_PER_PAGE=2
# NEW_AD_TEST_POSTS=2
# GOOGLE_CREDENTIALS_PATH=credentials.json
# Graph API limit per Page fetch (>= scan window). Raise if top posts are promoted and you need deeper history.
# PENDING_POSTS_FETCH_LIMIT=10

# Fallback min daily budget when API min absent (HKD); floor uses max(API_min+1, this)
MIN_DAILY_BUDGET=8

# --- Tier bands (cumulative from best / lowest CPC). Remainder after "tail" = bottom tier.
# TIER_CUTS={"champion":0.05,"strong":0.15,"middle":0.60,"explore":0.80,"tail":0.95}

# --- Budget allocator (HK pool: LTV score multiplier on 1/CPC)
# LTV_BUDGET_WEIGHT=1.5
# Upper cap vs current budget: middle tier
# BUDGET_CAP_MIDDLE=1.2
# Upper cap vs current: champion + strong (<=0 means effectively no cap)
# BUDGET_CAP_CHAMPION_STRONG=1.5
# Top fraction of pool for residual fill / trim (was hard-coded 0.5)
# ALLOC_RESIDUAL_TOP_FRACTION=0.5

# --- Sheet / no-op (avoid micro budget churn)
# Relative change below this => show?雁?nd snap suggestion to current
# BUDGET_NO_OP_THRESHOLD_DEFAULT=0.10
# Stricter band for champion / strong tiers
# BUDGET_NO_OP_THRESHOLD_TOP=0.15
# Forbid suggested budget below current for champion/strong unless PAUSE_ONLY
# BLOCK_DOWNGRADE_CHAMPION_STRONG=true

# Optional future: persist last suggestion for cool-down (not wired in code yet)
# BUDGET_HISTORY_ENABLED=false
# BUDGET_HISTORY_PATH=budget_history.json

# --- Pool sample gates (ai_optimizer)
# Whole-shop: skip P0?2 if active ads < this (default 3).
# MIN_ACTIVE_ADS_PER_SHOP=3
# Per-lane (shop,strategy): 璅?銝雲靽風 ??skip P0?2 if pool_n < MIN_POOL_SIZE (message shows this threshold).
# Default 3 ??2 ads in lane triggers 璅?銝雲. Set MIN_POOL_SIZE=2 to allow P0?2 with only 2 ads in that lane.
# MIN_POOL_SIZE=3
# MAX_RUNNING_ADS=15

# --- Google Sheets ---
SHEET_NAME=AdSurvivor_Report
RAW_SHEET_TAB=Sheet1
REFINED_SHEET_TAB=Sheet2
# ACTION_PLAN_TAB=AI_Action_Plan

# --- Meta Action Plan executors (execute_action_plan_*.py) ---
# Dry-run is default. To POST to Meta: set META_ACTION_EXECUTE_CONFIRM=YES and pass --execute.
# META_ACTION_EXECUTE_CONFIRM=YES
# Throttle between mutation POSTs (ms). See https://developers.facebook.com/docs/marketing-api/overview/rate-limiting/
META_ACTION_DELAY_MS=300
META_ACTION_MAX_RETRIES=5
# LOG_LEVEL=INFO
#
# Scripts (run from repo root, same .env as callfrommeta / ai_optimizer):
#   python execute_action_plan_pause.py
#   python execute_action_plan_budget.py
#   python execute_action_plan_audience.py
#   python execute_action_plan_new_ads.py
# Common flags: --execute --limit 1 --skip 0 --delay-ms 500 --verbose --tab AI_Action_Plan
#
# Permissions: ads_management required; Click-to-WhatsApp also needs pages_manage_ads, pages_read_engagement, pages_show_list.
# New ads: WhatsApp preflight is mandatory (destination_type + promoted_object.page_id). Override failures only with
#   python execute_action_plan_new_ads.py --execute --i-know-what-im-doing  (dangerous)
# P00 NEW_FROM_POST: empty ?格? + 銴ˊ??= same-page best-CPC ad set id from ai_optimizer (not brand-level SHOP_CONFIGS template)
#   template ad set after page_id guard; paste logged new_adset_id into ?格? to re-run without cloning. Dry-run = no Graph.

